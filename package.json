{
  "name": "game-master-bell-receiver",
  "private": true,
  "version": "0.0.0",
  "description": "Receiver PWA for Game Master Bell — installed on game master phones to receive bell calls",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --base=/game-master-bell-receiver/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^10.0.1",
    "fake-indexeddb": "^6.2.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
