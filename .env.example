# Base URL of the deployed call API (no trailing slash). Used for GET
# /vapid-key and POST/DELETE /subscriptions (see FR-R1, FR-R4).
# Copy this file to `.env.local` (gitignored) to override the committed
# `.env.development` default, or set it as a build-time env var in CI for
# production deploys (e.g. https://bell-api.gatherloop.id).
VITE_API_URL=http://127.0.0.1:8787
